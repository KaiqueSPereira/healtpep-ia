
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Manter o modelo legado para migração de dados
model PesoHistorico {
  id        String   @id @default(uuid())
  peso      String
  data      String // Mantido como String para compatibilidade
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  usuario   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Role {
  id             String             @id @default(cuid())
  name           String             @unique
  description    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  permissions    PermissionOnRole[]
  users          User[]
  resourceLimits ResourceLimit[]
}

model Permission {
  id          String             @id @default(cuid())
  name        String             @unique
  description String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  roles       PermissionOnRole[]
}

model PermissionOnRole {
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model ResourceLimit {
  id       String @id @default(cuid())
  roleId   String
  resource String
  limit    Int

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource])
  @@index([roleId])
}

model User {
  id               String                   @id @default(cuid())
  name             String?
  email            String                   @unique
  emailVerified    DateTime?
  image            String?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  roleId           String?
  accounts         Account[]
  Authenticator    Authenticator[]
  condicoesSaude   CondicaoSaude[]
  consultas        Consultas[]
  dadosSaude       DadosSaude?
  endereco         Endereco[]
  exames           Exame[]
  medicamentos     Medicamento[]
  notifications    Notification[]
  profissionais    Profissional[]
  sessions         Session[]
  unidades         UnidadeDeSaude[]
  role             Role?                    @relation(fields: [roleId], references: [id])
  historicoPeso    PesoHistorico[]
  acompanhamentos  AcompanhamentoCorporal[]
  bioimpedancias   Bioimpedancia[]
  metas            Meta[]

  @@index([roleId])
}

model AcompanhamentoCorporal {
  id        String                @id @default(uuid())
  data      DateTime
  peso      String?
  imc       String?
  pescoco   String?
  torax     String?
  cintura   String?
  quadril   String?
  bracoE    String?
  bracoD    String?
  pernaE    String?
  pernaD    String?
  pantE     String?
  pantD     String?
  userId    String
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  usuario   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  fotos     FotosAcompanhamento[]

  @@index([userId])
}

model FotosAcompanhamento {
  id               String                 @id @default(uuid())
  nomeArquivo      String
  mimetype         String?
  arquivo          Bytes?
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  acompanhamentoId String
  acompanhamento   AcompanhamentoCorporal @relation(fields: [acompanhamentoId], references: [id], onDelete: Cascade)

  @@index([acompanhamentoId])
}

model Bioimpedancia {
  id                String              @id @default(uuid())
  data              DateTime
  gorduraCorporal   String? 
  massaMuscular     String? 
  gorduraVisceral   String?
  taxaMetabolica    String?
  idadeCorporal     String?
  massaOssea        String?
  aguaCorporal      String?
  userId            String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  usuario           User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  anexos            AnexoBioimpedancia[]

  @@index([userId])
}

model AnexoBioimpedancia {
  id              String        @id @default(uuid())
  nomeArquivo     String
  mimetype        String?
  arquivo         Bytes?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  bioimpedanciaId String
  bioimpedancia   Bioimpedancia @relation(fields: [bioimpedanciaId], references: [id], onDelete: Cascade)

  @@index([bioimpedanciaId])
}

model Meta {
  id           String     @id @default(uuid())
  tipo         TipoMeta
  valorAlvo    String // String para criptografia
  valorInicial String? // String para criptografia
  dataInicio   DateTime
  dataFim      DateTime?
  status       StatusMeta @default(ATIVA)
  userId       String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  usuario      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AnvisaMedicamento {
  id             String @id @unique
  nome           String
  principioAtivo String

  @@index([nome])
}

model DadosSaude {
  id             String   @id @default(uuid())
  userId         String   @unique
  CNS            String?
  tipoSanguineo  String?
  sexo           String?
  dataNascimento String?
  altura         String?
  alergias       String[] @default([])
  usuario        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Authenticator {
  credentialID         String  @unique
  userId               String
  providerAccountId    String
  credentialPublicKey  String
  counter              Int
  credentialDeviceType String
  credentialBackedUp   Boolean
  transports           String?
  user                 User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
}

model Consultas {
  id               String          @id @default(uuid())
  data             DateTime
  tipodeexame      String?
  tipo             Consultatype
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  userId           String
  profissionalId   String?
  unidadeId        String?
  motivo           String
  consultaOrigemId String?
  anexos           AnexoConsulta[]
  Anotacoes        Anotacoes[]
  consultaOrigem   Consultas?      @relation("ConsultaRetorno", fields: [consultaOrigemId], references: [id], onUpdate: NoAction)
  retornos         Consultas[]     @relation("ConsultaRetorno")
  profissional     Profissional?   @relation(fields: [profissionalId], references: [id])
  unidade          UnidadeDeSaude? @relation(fields: [unidadeId], references: [id])
  usuario          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  Exame            Exame[]
  medicamentos     Medicamento[]
  condicoes        CondicaoSaude[] @relation("CondicaoSaudeToConsultas")

  @@index([userId])
  @@index([profissionalId])
  @@index([unidadeId])
  @@index([data])
}

model Anotacoes {
  id         String    @id @default(uuid())
  consultaId String
  anotacao   String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  consulta   Consultas @relation(fields: [consultaId], references: [id], onDelete: Cascade)

  @@index([consultaId])
}

model Endereco {
  id           String          @id @default(uuid())
  CEP          String
  numero       Int
  rua          String
  bairro       String
  municipio    String
  UF           String
  nome         String
  userId       String?
  unidadeId    String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  usuario      User?           @relation(fields: [userId], references: [id], onDelete: Cascade)
  unidadeSaude UnidadeDeSaude?

  @@index([userId])
  @@index([unidadeId])
}

model Profissional {
  id               String           @id @default(uuid())
  nome             String
  especialidade    String
  NumClasse        String           @unique
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  userId           String?
  condicoesSaude   CondicaoSaude[]  @relation("ProfissionalCondicoes")
  consultas        Consultas[]
  exames           Exame[]          @relation("ExameSolicitante")
  examesExecutados Exame[]          @relation("ExameExecutante")
  medicamentos     Medicamento[]
  usuario          User?            @relation(fields: [userId], references: [id])
  unidades         UnidadeDeSaude[] @relation("ProfissionalUnidades")

  @@index([userId])
}

model CondicaoSaude {
  id             String        @id @default(uuid())
  nome           String
  objetivo       String?
  dataInicio     DateTime
  observacoes    String?
  cidCodigo      String?
  cidDescricao   String?
  userId         String
  profissionalId String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  profissional   Profissional? @relation("ProfissionalCondicoes", fields: [profissionalId], references: [id])
  usuario        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  exames         Exame[]
  medicamentos   Medicamento[]
  consultas      Consultas[]   @relation("CondicaoSaudeToConsultas")

  @@index([userId])
  @@index([profissionalId])
}

model UnidadeDeSaude {
  id             String                     @id @default(uuid())
  nome           String
  tipo           String?
  enderecoId     String?                    @unique
  createdAt      DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt
  telefone       String?
  userId         String?
  abastecimentos AbastecimentoMedicamento[]
  consultas      Consultas[]
  exames         Exame[]
  endereco       Endereco?                  @relation(fields: [enderecoId], references: [id])
  usuario        User?                      @relation(fields: [userId], references: [id])
  profissionais  Profissional[]             @relation("ProfissionalUnidades")

  @@index([userId])
}

model Exame {
  id                       String           @id @default(uuid())
  nome                     String
  dataExame                DateTime?
  anotacao                 String?
  laudoFinalizado          Boolean          @default(false)
  userId                   String
  profissionalId           String?
  consultaId               String?
  unidadesId               String?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  tipo                     String?
  analiseIA                String?
  condicaoSaudeId          String?
  profissionalExecutanteId String?
  condicaoSaude            CondicaoSaude?   @relation(fields: [condicaoSaudeId], references: [id])
  consulta                 Consultas?       @relation(fields: [consultaId], references: [id])
  profissional             Profissional?    @relation("ExameSolicitante", fields: [profissionalId], references: [id])
  profissionalExecutante   Profissional?    @relation("ExameExecutante", fields: [profissionalExecutanteId], references: [id])
  unidades                 UnidadeDeSaude?  @relation(fields: [unidadesId], references: [id])
  usuario                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  resultados               ResultadoExame[]
  anexos                   AnexoExame[]

  @@index([userId])
  @@index([profissionalId])
  @@index([consultaId])
  @@index([unidadesId])
  @@index([condicaoSaudeId])
  @@index([profissionalExecutanteId])
}

model ResultadoExame {
  id         String   @id @default(uuid())
  exameId    String
  nome       String
  valor      String
  unidade    String?
  referencia String?
  categoria  String?
  createdAt  DateTime @default(now())
  exame      Exame    @relation(fields: [exameId], references: [id], onDelete: Cascade)

  @@index([exameId])
}

model AnexoExame {
  id           String   @id @default(uuid())
  nomeArquivo  String
  mimetype     String?
  arquivo      Bytes?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  exameId      String
  exame        Exame    @relation(fields: [exameId], references: [id], onDelete: Cascade)

  @@index([exameId])
}

model AnexoConsulta {
  id          String    @id @default(uuid())
  nomeArquivo String
  tipo        TipoAnexo
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  consultaId  String
  arquivo     Bytes?
  mimetype    String?
  consulta    Consultas @relation(fields: [consultaId], references: [id], onDelete: Cascade)

  @@index([consultaId])
}

model Medicamento {
  id                       String                  @id @default(uuid())
  nome                     String
  posologia                String?
  dataInicio               DateTime
  dataFim                  DateTime?
  status                   StatusMedicamento
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  userId                   String
  profissionalId           String?
  consultaId               String?
  estoque                  Int?                    @default(0)
  frequenciaNumero         Int?
  frequenciaTipo           FrequenciaTipo?
  quantidadeCaixa          Int?
  quantidadeDose           Float?
  forma                    String?
  tipo                     TipoMedicamento
  condicaoSaudeId          String?
  linkBula                 String?
  principioAtivo           String?
  ultimaAtualizacaoEstoque DateTime?
  abastecimentos           AbastecimentoMedicamento[]
  condicaoSaude            CondicaoSaude?             @relation(fields: [condicaoSaudeId], references: [id])
  consulta                 Consultas?                 @relation(fields: [consultaId], references: [id])
  profissional             Profissional?              @relation(fields: [profissionalId], references: [id])
  usuario                  User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  notifications            Notification[]

  @@index([userId])
  @@index([profissionalId])
  @@index([consultaId])
  @@index([condicaoSaudeId])
}

model Notification {
  id            String       @id @default(cuid())
  title         String
  message       String
  url           String?
  isRead        Boolean      @default(false)
  createdAt     DateTime     @default(now())
  userId        String
  medicamentoId String?
  relatedId     String?
  relatedModel  String?
  type          String
  medicamento   Medicamento? @relation(fields: [medicamentoId], references: [id])
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([medicamentoId])
  @@index([relatedId, relatedModel])
}

model ErrorLog {
  id        String   @id @default(uuid())
  message   String
  stack     String?
  url       String?
  level     String?
  component String?
  timestamp DateTime @default(now())
}

model AbastecimentoMedicamento {
  id               String          @id @default(uuid())
  data             String // Mantido como String por solicitação
  quantidade       String
  observacoes      String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  medicamentoId    String
  unidadeDeSaudeId String?
  medicamento      Medicamento     @relation(fields: [medicamentoId], references: [id], onDelete: Cascade)
  unidadeDeSaude   UnidadeDeSaude? @relation(fields: [unidadeDeSaudeId], references: [id])

  @@index([medicamentoId])
  @@index([unidadeDeSaudeId])
}

model BiomarkerRule {
  id                String @id @default(cuid())
  normalizedRawName String @unique
  standardizedName  String
  category          String

  @@index([standardizedName])
  @@index([category])
}

enum TipoMeta {
  PESO
  GORDURA_CORPORAL
  MASSA_MUSCULAR
}

enum StatusMeta {
  ATIVA
  CONCLUIDA
  CANCELADA
}

enum TipoAnexo {
  Encaminhamento
  Atestado_Declaracao
  Receita_Medica
  Relatorio
  Outro
}

enum StatusMedicamento {
  Ativo
  Concluido
  Suspenso
}

enum FrequenciaTipo {
  Hora
  Dia
  Semana
  Mes
}

enum TipoMedicamento {
  Uso_Continuo
  Tratamento_Clinico
  Esporadico
}

enum Consultatype {
  Rotina
  Exame
  Emergencia
  Retorno
  Tratamento
}
